{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Ai": {
    "Enabled": false,
    "DefaultProvider": "ollama",
    "Features": {
      "ExplanationEnrichment": {
        "Enabled": true,
        "Provider": "ollama",
        "Model": null,
        "TimeoutSeconds": 45,
        "MaxOutputTokens": 220,
        "Temperature": 0.2,
        "AllowFallback": true
      },
      "RootCauseNarrative": {
        "Enabled": true,
        "Provider": "ollama",
        "Model": null,
        "TimeoutSeconds": 60,
        "MaxOutputTokens": 320,
        "Temperature": 0.2,
        "AllowFallback": true
      }
    },
    "Providers": {
      "ollama": {
        "Type": "Ollama",
        "Enabled": true,
        "DefaultModel": "qwen3:8b",
        "BaseUrl": "http://localhost:11434",
        "RequiresApiKey": false,
        "Capabilities": {
          "SupportsStreaming": true,
          "SupportsToolCalling": true,
          "SupportsJsonMode": true,
          "SupportsOpenAiCompatibility": false,
          "IsLocal": true
        }
      },
      "openrouter": {
        "Type": "OpenRouter",
        "Enabled": false,
        "DefaultModel": "openai/gpt-5-mini",
        "BaseUrl": "https://openrouter.ai/api/v1",
        "RequiresApiKey": true,
        "Capabilities": {
          "SupportsStreaming": true,
          "SupportsToolCalling": true,
          "SupportsJsonMode": true,
          "SupportsOpenAiCompatibility": true,
          "IsLocal": false
        }
      }
    }
  },
  "Telemetry": {
    "Enabled": true,
    "ConsoleExporterEnabled": false,
    "TopFingerprintLimit": 10
  },
  "Privacy": {
    "RawContentStorageEnabled": true,
    "RedactRawContentOnWrite": true,
    "RawContentRetentionDays": 7,
    "AnalysisRetentionDays": 90
  },
  "AllowedHosts": "*"
}
