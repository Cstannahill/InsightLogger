{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Ai": {
    "Enabled": false,
    "Features": {
      "ExplanationEnrichment": {
        "Enabled": true,
        "Provider": "ollama",
        "AllowFallback": true
      },
      "RootCauseNarrative": {
        "Enabled": true,
        "Provider": "ollama",
        "AllowFallback": true
      }
    }
  },
  "Telemetry": {
    "Enabled": true,
    "ConsoleExporterEnabled": false,
    "TopFingerprintLimit": 10
  },
  "Privacy": {
    "RawContentStorageEnabled": true,
    "RedactRawContentOnWrite": true,
    "RawContentRetentionDays": 7,
    "AnalysisRetentionDays": 90
  }
}
